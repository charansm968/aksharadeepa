<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/quizHeader"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_primary"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:paddingTop="34dp" android:paddingBottom="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"/>
            <TextView
                android:id="@+id/tvChapterTitle"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF" android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="6dp"
                android:maxLines="2" android:ellipsize="end"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@color/white"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="5dp" android:paddingBottom="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="&#9201; " android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="15:00" android:textSize="15sp"
                    android:fontFamily="sans-serif-bold" android:textColor="@color/primary_dark"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="10px">
            <TextView
                android:id="@+id/tvQuestionNum"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Q 1 / 10" android:textColor="#DDFFFFFF" android:textSize="13sp"/>
            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Score: 0" android:textColor="#FFFFFF" android:textSize="13sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/pbQuizProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:progressTint="#FFD700"
            android:progressBackgroundTint="#44FFFFFF"
            android:max="10" android:progress="1"/>
    </LinearLayout>

    <!-- Scrollable questions -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp" android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/quizHeader"
        app:layout_constraintBottom_toTopOf="@id/btnSubmit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">

            <!-- Question Card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp" app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Question" android:textSize="11sp"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_number_badge"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvQuestion"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="16sp" android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" android:layout_marginTop="10dp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Option A -->
            <androidx.cardview.widget.CardView android:id="@+id/cvOption1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="9dp"
                app:cardCornerRadius="12dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvOption1Label"
                        android:layout_width="30dp" android:layout_height="30dp"
                        android:gravity="center" android:text="A"
                        android:textSize="13sp" android:fontFamily="sans-serif-bold"
                        android:textColor="@color/white" android:background="@drawable/bg_number_badge"/>
                    <TextView android:id="@+id/tvOption1"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="12dp" android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Option B -->
            <androidx.cardview.widget.CardView android:id="@+id/cvOption2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="9dp"
                app:cardCornerRadius="12dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvOption2Label"
                        android:layout_width="30dp" android:layout_height="30dp"
                        android:gravity="center" android:text="B"
                        android:textSize="13sp" android:fontFamily="sans-serif-bold"
                        android:textColor="@color/white" android:background="@drawable/bg_number_badge"/>
                    <TextView android:id="@+id/tvOption2"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="12dp" android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Option C -->
            <androidx.cardview.widget.CardView android:id="@+id/cvOption3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="9dp"
                app:cardCornerRadius="12dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvOption3Label"
                        android:layout_width="30dp" android:layout_height="30dp"
                        android:gravity="center" android:text="C"
                        android:textSize="13sp" android:fontFamily="sans-serif-bold"
                        android:textColor="@color/white" android:background="@drawable/bg_number_badge"/>
                    <TextView android:id="@+id/tvOption3"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="12dp" android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Option D -->
            <androidx.cardview.widget.CardView android:id="@+id/cvOption4"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="9dp"
                app:cardCornerRadius="12dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvOption4Label"
                        android:layout_width="30dp" android:layout_height="30dp"
                        android:gravity="center" android:text="D"
                        android:textSize="13sp" android:fontFamily="sans-serif-bold"
                        android:textColor="@color/white" android:background="@drawable/bg_number_badge"/>
                    <TextView android:id="@+id/tvOption4"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="12dp" android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Feedback card -->
            <androidx.cardview.widget.CardView android:id="@+id/cvFeedback"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:visibility="gone" android:layout_marginTop="6dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvFeedbackTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="16sp" android:fontFamily="sans-serif-bold"/>
                    <TextView android:id="@+id/tvCorrectAnswerInfo"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="5dp" android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Submit button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmit"
        android:layout_width="0dp" android:layout_height="52dp"
        android:text="Submit Answer"
        android:textSize="16sp" android:fontFamily="sans-serif-medium"
        android:layout_margin="14dp"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
