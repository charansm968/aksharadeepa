<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="148dp"
    android:layout_margin="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="5dp">
    <RelativeLayout
        android:id="@+id/clSubjectBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_subject_science"
        android:padding="14dp">
        <TextView
            android:id="@+id/tvSubjectEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="26sp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"/>
        <TextView
            android:id="@+id/tvProgressPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="13sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="#FFFFFF"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"/>
        <TextView
            android:id="@+id/tvSubjectName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-bold"
            android:layout_below="@id/tvSubjectEmoji"
            android:layout_marginTop="6dp"
            android:shadowColor="#80000000"
            android:shadowDx="0" android:shadowDy="1" android:shadowRadius="2"/>
        <TextView
            android:id="@+id/tvChapterInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#EEFFFFFF"
            android:textSize="11sp"
            android:layout_below="@id/tvSubjectName"
            android:layout_marginTop="2dp"/>
        <ProgressBar
            android:id="@+id/pbSubject"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:progressTint="#FFFFFF"
            android:progressBackgroundTint="#50FFFFFF"
            android:max="100"
            android:progress="0"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
