<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="16dp" app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Coloured header strip -->
        <LinearLayout android:id="@+id/llSubjectHeader"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/bg_subject_science">
            <TextView android:id="@+id/tvEmoji"
                android:layout_width="46dp" android:layout_height="46dp"
                android:gravity="center" android:textSize="24sp"
                android:background="@color/white"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView android:id="@+id/tvSubjectName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Subject" android:textColor="#FFFFFF"
                    android:textSize="16sp" android:fontFamily="sans-serif-bold"
                    android:shadowColor="#80000000"
                    android:shadowDx="0" android:shadowDy="1" android:shadowRadius="2"/>
                <TextView android:id="@+id/tvChapterCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#DDFFFFFF" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:id="@+id/tvPct"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#FFFFFF" android:textSize="20sp"
                android:fontFamily="sans-serif-bold"
                android:shadowColor="#80000000"
                android:shadowDx="0" android:shadowDy="1" android:shadowRadius="2"/>
        </LinearLayout>

        <!-- Progress + button row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">
            <ProgressBar android:id="@+id/pbSubject"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="8dp"
                android:progressDrawable="@drawable/progress_bar_custom"
                android:max="100" android:progress="0"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="10dp">
                <TextView android:id="@+id/tvDoneLabel"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 / 0 completed" android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewChapters"
                    android:layout_width="wrap_content" android:layout_height="34dp"
                    android:text="View Chapters" android:textSize="12sp"
                    android:insetTop="0dp" android:insetBottom="0dp"
                    app:cornerRadius="10dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
