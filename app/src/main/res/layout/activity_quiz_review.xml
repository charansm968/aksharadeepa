<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Result Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_gradient_primary"
            android:paddingTop="44dp" android:paddingBottom="28dp"
            android:paddingStart="20dp" android:paddingEnd="20dp">
            <TextView android:id="@+id/tvResultEmoji"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="&#127942;" android:textSize="56sp"/>
            <TextView android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Excellent!" android:textColor="#FFFFFF"
                android:textSize="26sp" android:fontFamily="sans-serif-bold"
                android:layout_marginTop="10dp"/>
            <TextView android:id="@+id/tvSubjectChapter"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFEECC" android:textSize="13sp"
                android:layout_marginTop="4dp"/>
            <!-- Score Circle -->
            <androidx.cardview.widget.CardView
                android:layout_width="130dp" android:layout_height="130dp"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="65dp" app:cardElevation="6dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvScoreNum"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0/10" android:textSize="26sp"
                        android:fontFamily="sans-serif-bold" android:textColor="@color/primary_dark"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="score" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvScorePercent"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="18sp"
                        android:fontFamily="sans-serif-bold" android:textColor="@color/success"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Stats -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_margin="14dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="7dp"
                app:cardCornerRadius="14dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#9989;" android:textSize="22sp"/>
                    <TextView android:id="@+id/tvCorrectCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="22sp"
                        android:fontFamily="sans-serif-bold" android:textColor="@color/success"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Correct" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="7dp"
                app:cardCornerRadius="14dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#10060;" android:textSize="22sp"/>
                    <TextView android:id="@+id/tvWrongCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="22sp"
                        android:fontFamily="sans-serif-bold" android:textColor="@color/error"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Wrong" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Review Answers"
            android:textSize="16sp" android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"
            android:layout_marginStart="14dp" android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvReview"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="14dp" android:layout_marginEnd="14dp"
            android:nestedScrollingEnabled="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTryAgain"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Try Again"
            android:textSize="15sp" android:layout_margin="14dp"
            android:layout_marginBottom="6dp"
            app:cornerRadius="14dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/primary" android:textColor="@color/primary"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToSyllabus"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Back to Chapters"
            android:textSize="15sp"
            android:layout_marginStart="14dp" android:layout_marginEnd="14dp"
            android:layout_marginBottom="28dp"
            app:cornerRadius="14dp"/>
    </LinearLayout>
</ScrollView>
